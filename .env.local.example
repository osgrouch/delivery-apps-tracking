# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — service role key, server-only, used by scripts/import-shifts.ts.
# NEVER expose this in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sentry — Project Settings > Client Keys (DSN). DSNs are safe to expose
# client-side, so one value covers client, server, and edge configs.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Sentry — only needed locally/in CI to upload source maps during `next build`.
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

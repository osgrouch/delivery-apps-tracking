# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — service role key, server-only, used by scripts/import-shifts.ts.
# NEVER expose this in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sentry — Project Settings > Client Keys (DSN). DSNs are safe to expose
# client-side. SENTRY_DSN is optional — server/edge configs fall back to
# NEXT_PUBLIC_SENTRY_DSN if unset, but set it separately if you ever want
# server-side errors to go to a different Sentry project.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_DSN=

# Sentry — only needed locally/in CI to upload source maps during `next build`.
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
